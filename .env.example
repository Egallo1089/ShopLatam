# .env.example - NUNCA COMMITTEAR VARIABLES SECRETAS REALES
# Copiar este archivo a .env.local o .env.development y llenar valores reales

# ─── Database ─────────────────────────────────────────
# Para desarrollo: usar SQLite
# DATABASE_URL=sqlite:///./backend/shoplatam_local.db
#
# Para producción: PostgreSQL/Supabase
# DATABASE_URL=postgresql://user:password@host:5432/database

DATABASE_URL=sqlite:///./backend/shoplatam_local.db

# ─── JWT / Auth (CAMBIAR EN PRODUCCIÓN) ──────────────
# Generar secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev_secret_key_shoplatam_2026_CHANGE_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Supabase (Storage + optional Auth) ───────────────
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_BUCKET=products

# ─── Inngest (Background jobs) ────────────────────────
INNGEST_EVENT_KEY=evt_...
INNGEST_SIGNING_KEY=signkey_...

# ─── WhatsApp Business API ────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=shoplatam_verify_token_2026
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# ─── PayPhone Ecuador (Pagos) ────────────────────────
PAYPHONE_TOKEN=your_payphone_token_here
PAYPHONE_STORE_ID=your_store_id_here
PAYPHONE_API_URL=https://pay.payphonetodoesmas.com/api

# ─── App ──────────────────────────────────────────────
APP_ENV=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3004","http://localhost:5173"]
